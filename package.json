{
  "name": "@liangfu/uniadapter",
  "version": "2.0.0",
  "type": "module",
  "description": "UniAdapter VibeUI - 首个 shadcn 风格小程序组件注册表 + AI VibeCoding 引擎。一套代码适配 H5/微信/支付宝/抖音/小红书，npx @liangfu/uniadapter add button card dialog 即可获得完整源代码。",
  "keywords": [
    "vibe-ui",
    "shadcn",
    "mini-program",
    "wechat",
    "alipay",
    "douyin",
    "cross-platform",
    "component-library",
    "vibe-coding",
    "ai-ui",
    "typescript",
    "multi-platform",
    "adapter",
    "framework",
    "小程序",
    "组件库",
    "跨端",
    "AI生成UI"
  ],
  "author": "liangfuliang541-pixel",
  "license": "MIT",
  "homepage": "https://github.com/liangfuliang541-pixel/uniadapter",
  "repository": {
    "type": "git",
    "url": "https://github.com/liangfuliang541-pixel/uniadapter.git"
  },
  "bugs": {
    "url": "https://github.com/liangfuliang541-pixel/uniadapter/issues"
  },
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "build:lib": "vite build --config vite.lib.no-dts.config.ts",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "docs:generate": "npx docs-generator --source src --output docs/api",
    "docs:serve": "npx docsify serve docs",
    "docs:build": "npx docsify build docs",
    "plugin:example": "tsx examples/plugin-example.ts",
    "plugin:test": "vitest run --reporter=verbose tests/plugin-system.test.ts",
    "plugin:build": "tsc --project tsconfig.plugin.json",
    "cli:init": "tsx src/cli/index.ts init",
    "cli": "node dist/cli.js"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@nx/workspace": "^19.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.0.18",
    "clsx": "^2.1.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^3.1.0",
    "husky": "^9.0.11",
    "jsdom": "^27.4.0",
    "lint-staged": "^15.2.2",
    "nx": "^19.0.0",
    "prettier": "^3.2.5",
    "tailwind-merge": "^3.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "bin": {
    "@liangfu/uniadapter": "./dist/cli.js"
  }
}
